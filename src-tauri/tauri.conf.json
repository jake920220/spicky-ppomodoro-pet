{
  "productName": "Spiky Ppomodoro pet",
  "version": "0.1.0",
  "identifier": "com.spiky.pet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Junhyun Kim",
    "homepage": "https://github.com/jake920220/spicky-ppomodoro-pet",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "Korean",
          "English"
        ],
        "displayLanguageSelector": false
      }
    }
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "security": {
      "capabilities": ["main-capability"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Spiky Ppomodoro pet",
        "width": 340,
        "height": 460,
        "center": false,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false
      }
    ]
  }
}
